{
	quest.03C002E4A4515E0E.quest_desc: [
		"Spice of Life: Carrot Edition encourages players to eat many different kinds of food by rewarding them for trying new things. Each time you reach a goal for eating new foods, you gain extra hearts that permanently increase your maximum health."
		""
		"The Food Book shows which foods you have already eaten and helps you track your progress toward earning your next extra heart."
	]
	quest.03C002E4A4515E0E.quest_subtitle: "Craft the Food Book"
}
